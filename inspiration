<!-- FOOTER -->
<footer>
    <div class="container">
        <div class="footer-inner">
            <span class="footer-mark">+ Intersections Advisory</span>
            <span class="footer-copy">© 2026 Intersections Advisory</span>
        </div>
    </div>
</footer>

</body>
</html>
